{
  "author": "Aaron Reisman <aaron@lifeiscontent.net>",
  "dependencies": {
    "@fastify/auth": "4.4.0",
    "@fastify/autoload": "5.8.0",
    "@fastify/bearer-auth": "9.1.0",
    "@fastify/cors": "8.4.2",
    "@fastify/postgres": "5.2.2",
    "@fastify/swagger": "8.12.1",
    "@fastify/swagger-ui": "2.0.1",
    "@fastify/type-provider-typebox": "3.5.0",
    "@sinclair/typebox": "0.31.28",
    "ajv-errors": "3.0.0",
    "bcryptjs": "2.4.3",
    "fastify": "4.24.3",
    "fastify-list-routes": "1.0.0",
    "fastify-plugin": "4.5.1",
    "jsonwebtoken": "9.0.2",
    "kysely": "0.26.3",
    "pg": "8.11.3",
    "slugify": "1.6.6"
  },
  "description": "Example Realworld API using Fastify, Kysley, Postgres and TypeScript",
  "devDependencies": {
    "@faker-js/faker": "8.3.1",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.5",
    "@types/node": "20.10.4",
    "@types/pg": "8.10.9",
    "@typescript-eslint/eslint-plugin": "6.14.0",
    "@typescript-eslint/parser": "6.14.0",
    "@vitest/coverage-v8": "1.0.4",
    "dotenv": "16.3.1",
    "eslint": "8.55.0",
    "kysely-codegen": "0.11.0",
    "nodemon": "3.0.2",
    "prettier": "3.1.1",
    "ts-node": "10.9.2",
    "tsx": "4.6.2",
    "type-fest": "4.8.3",
    "typescript": "5.3.3",
    "vitest": "1.0.4"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [],
  "license": "ISC",
  "main": "index.js",
  "name": "fastify-realworld",
  "packageManager": "pnpm@8.11.0",
  "scripts": {
    "dev": "nodemon",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "kysley-codegen": "kysely-codegen --env-file .env.development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "node --import tsx scripts/migrate.ts",
    "migrate:down": "node --import tsx scripts/migrate/down.ts",
    "prepare": "tsc",
    "seed": "node --import tsx scripts/seed.ts",
    "start": "node lib/src/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "type:check": "tsc --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}